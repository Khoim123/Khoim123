			pcall(function()
				updatePlayerListUI()
				updateStatus()
			end)
		end
	end)

	Players.PlayerAdded:Connect(function(p)
		task.wait(0.5)
		pcall(function()
			if EspEnabled then updateEsp() end
			updatePlayerListUI()
		end)
	end)

	Players.PlayerRemoving:Connect(function(p)
		pcall(function()
			WhitelistedPlayers[p.UserId] = nil
			updateStatus()
			task.wait(0.3)
			if EspEnabled then updateEsp() end
			updatePlayerListUI()
		end)
	end)

	updateStatus()
end)

