			fill.Size = UDim2.new(relative, 0, 1, 0)
			knob.Position = UDim2.new(relative, -14, 0, 29)
			valLbl.Text = string.format(formatStr, newVal)
			pcall(setter, newVal)
		end

		container.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				local pos = input.Position
				local inBounds = pos.X >= hitbox.AbsolutePosition.X and pos.X <= hitbox.AbsolutePosition.X + hitbox.AbsoluteSize.X
					and pos.Y >= hitbox.AbsolutePosition.Y and pos.Y <= hitbox.AbsolutePosition.Y + hitbox.AbsoluteSize.Y
				if inBounds then
					dragging = true
					update(input)
				end
			end
		end)

		container.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				dragging = false
			end
		end)

		return container
	end

	createSlider(RightColumn, "🔭 TẦM NHÌN", 10, 1000, AimbotDistance, function(v) AimbotDistance = v; updateStatus() end, "%.0f m")
	createSlider(RightColumn, "🌀 ĐỘ MƯỢT", 0.01, 1.0, Smoothness, function(v) Smoothness = v; updateStatus() end, "%.2f")

	-- SLIDER ĐỘ MỜ NÚT - Xử lý ImageButton đúng cách
	createSlider(RightColumn, "👁️ ĐỘ MỜ NÚT", 0, 0.99, ToggleTransparency, function(v)
		ToggleTransparency = v
		if MainToggle then
			MainToggle.ImageTransparency = v
			MainToggle.BackgroundTransparency = 0.2 + (v * 0.8)
			local shadow = MainToggle:FindFirstChild("Shadow")
			if shadow then
				shadow.ImageTransparency = 0.6 + (v * 0.4)
			end
		end
	end, "%.2f")

	-- Player list header
	local listHeader = Instance.new("Frame", RightColumn)
	listHeader.Size = UDim2.new(1,0,0,30)
	listHeader.BackgroundTransparency = 1
	local lblList = Instance.new("TextLabel", listHeader)
	lblList.Size = UDim2.new(0.6,0,1,0)
	lblList.Text = "👥 WHITELIST"
	lblList.TextSize = 13
	lblList.Font = Enum.Font.GothamBold
	lblList.TextXAlignment = Enum.TextXAlignment.Left
	lblList.BackgroundTransparency = 1
	lblList.TextColor3 = Color3.fromRGB(255,215,0)

	local RefreshBtn = Instance.new("TextButton", listHeader)
	RefreshBtn.Size = UDim2.new(0,60,0,24)
	RefreshBtn.Position = UDim2.new(1, -65, 0, 3)
	RefreshBtn.BackgroundColor3 = Color3.fromRGB(0,120,200)
	RefreshBtn.Text = "⟳ LÀM MỚI"
	RefreshBtn.TextColor3 = Color3.new(1,1,1)
	RefreshBtn.Font = Enum.Font.GothamBold
	RefreshBtn.TextSize = 11
	RefreshBtn.AutoButtonColor = false
	Instance.new("UICorner", RefreshBtn).CornerRadius = UDim.new(0,6)
	RefreshBtn.MouseButton1Click:Connect(function() pcall(updatePlayerListUI) end)

	-- Scrollable player list
	local pListScroll = Instance.new("ScrollingFrame", RightColumn)
	pListScroll.Size = UDim2.new(1,0,0,100)
	pListScroll.BackgroundTransparency = 1
	pListScroll.ScrollBarThickness = 4
	pListScroll.ScrollBarImageColor3 = Color3.fromRGB(100,100,120)
	pListScroll.BorderSizePixel = 0
	pListScroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
	pListScroll.CanvasSize = UDim2.new(0,0,0,0)

	PlayerListFrame = Instance.new("Frame", pListScroll)
	PlayerListFrame.Name = "PlayerListContent"
	PlayerListFrame.Size = UDim2.new(1,0,0,0)
	PlayerListFrame.BackgroundTransparency = 1
	PlayerListFrame.AutomaticSize = Enum.AutomaticSize.Y

	local listLayout = Instance.new("UIListLayout", PlayerListFrame)
	listLayout.Padding = UDim.new(0, 4)
	listLayout.SortOrder = Enum.SortOrder.LayoutOrder

	-- Status label
	StatusLabel = Instance.new("TextLabel", RightColumn)
	StatusLabel.Size = UDim2.new(1,0,0,60)
	StatusLabel.BackgroundColor3 = Color3.fromRGB(25,25,40)
	StatusLabel.TextSize = 12
	StatusLabel.Font = Enum.Font.Gotham
	StatusLabel.TextWrapped = true
	StatusLabel.TextColor3 = Color3.fromRGB(150,255,150)
	StatusLabel.TextXAlignment = Enum.TextXAlignment.Left
	StatusLabel.TextYAlignment = Enum.TextYAlignment.Top
	Instance.new("UICorner", StatusLabel).CornerRadius = UDim.new(0,8)
	local pad = Instance.new("UIPadding", StatusLabel)
	pad.PaddingTop = UDim.new(0,6)
	pad.PaddingLeft = UDim.new(0,8)

	-- Drag và events
	MainToggle.MouseButton1Click:Connect(function() 
		MainFrame.Visible = not MainFrame.Visible
		if MainFrame.Visible then
			TweenService:Create(MainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Back), {BackgroundTransparency = 0.15}):Play()
		end
	end)
	CloseBtn.MouseButton1Click:Connect(function() MainFrame.Visible = false end)

	Header.InputBegan:Connect(function(input, gameProcessed)
		if gameProcessed then return end
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragState.isDraggingFrame = true
			dragState.dragStart = input.Position
			dragState.startPos = MainFrame.Position
		end
	end)

	connectionStore.inputChanged = UserInputService.InputChanged:Connect(function(input, gameProcessed)
		if gameProcessed then return end
		if dragState.isDraggingFrame and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local delta = input.Position - dragState.dragStart
			MainFrame.Position = UDim2.new(
				dragState.startPos.X.Scale,
				dragState.startPos.X.Offset + delta.X,
				dragState.startPos.Y.Scale,
				dragState.startPos.Y.Offset + delta.Y
			)
		end
	end)

	connectionStore.inputEnded = UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragState.isDraggingFrame = false
		end
	end)
end

function updateStatus()
	if not StatusLabel then return end
	pcall(function()
		local count = 0
		for _, v in pairs(WhitelistedPlayers) do if v == true then count = count + 1 end end
		local targetTxt = count > 0 and string.format("🎯 %d người", count) or "🌍 Tất cả"
		local partTxt = AimPart == "Head" and "Đầu" or (AimPart == "Torso" and "Thân" or "Chân")
		local modeTxt = TargetPriority == "Nearest" and "Gần nhất" or (TargetPriority == "Weakest" and "Yếu máu" or "Mạnh máu")
		StatusLabel.Text = string.format("⚡ AIM: %s  |  CAM: %s\n🎲 Target: %s [%s]  |  🧬 Part: %s\n📏 Range: %.0f m",
			AimbotEnabled and "BẬT" or "TẮT",
			CamlockEnabled and "BẬT" or "TẮT",
			targetTxt, modeTxt, partTxt, AimbotDistance)
	end)
end

function updatePlayerListUI()
	if not PlayerListFrame then return end
	pcall(function()
		for _, child in ipairs(PlayerListFrame:GetChildren()) do
			if child:IsA("TextButton") then child:Destroy() end
		end

		local y = 0
		for _, p in ipairs(Players:GetPlayers()) do
			if p ~= player then
				local btn = Instance.new("TextButton")
				btn.Parent = PlayerListFrame
				btn.Size = UDim2.new(1,0,0,28)
				btn.LayoutOrder = y
				btn.BackgroundColor3 = Color3.fromRGB(35,35,50)
				btn.TextColor3 = Color3.new(1,1,1)
				btn.Font = Enum.Font.Gotham
				btn.TextSize = 12
				btn.AutoButtonColor = false
				Instance.new("UICorner", btn).CornerRadius = UDim.new(0,6)

				local isWhitelisted = WhitelistedPlayers[p.UserId] == true
				btn.Text = (isWhitelisted and "✅ " or "⚪ ") .. p.Name
				btn.BackgroundColor3 = isWhitelisted and Color3.fromRGB(0,140,70) or Color3.fromRGB(35,35,50)

				btn.MouseButton1Click:Connect(function()
					if WhitelistedPlayers[p.UserId] then
						WhitelistedPlayers[p.UserId] = nil
					else
						WhitelistedPlayers[p.UserId] = true
					end
					pcall(updatePlayerListUI)
					pcall(updateStatus)
				end)
				y = y + 1
			end
		end
	end)
end

