local function getCharacter()
	return player.Character or player.CharacterAdded:Wait()
end

local function getTargetPart(char, partName)
	if not char then return nil end
	if partName == "Head" then
		return char:FindFirstChild("Head")
	elseif partName == "Torso" then
		return char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
	elseif partName == "Legs" then
		return char:FindFirstChild("LowerTorso") or char:FindFirstChild("HumanoidRootPart")
	end
	return char:FindFirstChild("HumanoidRootPart")
end

local function isVisible(targetPart)
	if not WallCheckEnabled then return true end
	if not targetPart or not Camera then return false end
	if not character or not character:FindFirstChild("HumanoidRootPart") then return false end

	local origin = Camera.CFrame.Position
	local direction = targetPart.Position - origin
	if direction.Magnitude <= 0 then return true end

	local rayParams = RaycastParams.new()
	rayParams.FilterType = Enum.RaycastFilterType.Exclude
	rayParams.FilterDescendantsInstances = { character }

	local success, result = pcall(function()
		return workspace:Raycast(origin, direction, rayParams)
	end)

	if not success then return false end
	if result and result.Instance then
		if result.Instance:IsDescendantOf(targetPart.Parent) then
			return true
		else
			return false
		end
	end
	return true
end

-- ==================== CORE LOGIC (FIXED WHITELIST) ====================
local function getBestTarget()
	local candidates = {}
	if not character or not character:FindFirstChild("HumanoidRootPart") then return nil end
	local myRoot = character.HumanoidRootPart

	local hasWhitelist = false
	for _, v in pairs(WhitelistedPlayers) do
		if v == true then
			hasWhitelist = true
			break
		end
	end

	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= player and p.Character and p.Parent then
			local allowed = true
			if hasWhitelist and not WhitelistedPlayers[p.UserId] then
				allowed = false
			end

			if allowed then
				local pChar = p.Character
				local hum = pChar:FindFirstChildOfClass("Humanoid")
				local pRoot = pChar:FindFirstChild("HumanoidRootPart")
				local pPart = getTargetPart(pChar, AimPart)

				if hum and hum.Health > 0 and pRoot and pPart then
					local success, dist = pcall(function()
						return (pRoot.Position - myRoot.Position).Magnitude
					end)

					if success and dist and dist <= AimbotDistance and isVisible(pPart) then
						table.insert(candidates, { 
							char = pChar, 
							dist = dist, 
							health = hum.Health
						})
					end
				end
			end
		end
	end

	if #candidates == 0 then return nil end

	local sortSuccess = pcall(function()
		if TargetPriority == "Nearest" then
			table.sort(candidates, function(a, b) return (a.dist or math.huge) < (b.dist or math.huge) end)
		elseif TargetPriority == "Weakest" then
			table.sort(candidates, function(a, b) return (a.health or math.huge) < (b.health or math.huge) end)
		elseif TargetPriority == "Strongest" then
			table.sort(candidates, function(a, b) return (a.health or 0) > (b.health or 0) end)
		end
	end)

	if not sortSuccess then return nil end
	if candidates[1] and candidates[1].char then return candidates[1].char end
	return nil
end

local function updateAimbot()
	if not AimbotEnabled then return end
	if not character then return end
	local myRoot = character:FindFirstChild("HumanoidRootPart")
	local myHum = character:FindFirstChildOfClass("Humanoid")
	if not myRoot or not myHum or myHum.Health <= 0 then return end

	local target = getBestTarget()
	if not target then return end

	local targetPart = getTargetPart(target, AimPart)
	if not targetPart then return end

	local success, targetPosition = pcall(function() return targetPart.Position end)
	if not success or not targetPosition then return end

	if not CharacterTilt then
		targetPosition = Vector3.new(targetPosition.X, myRoot.Position.Y, targetPosition.Z)
	end

	local goalCFrame = CFrame.lookAt(myRoot.Position, targetPosition)
	myRoot.CFrame = myRoot.CFrame:Lerp(goalCFrame, math.clamp(Smoothness, 0, 1))
end

local function updateCamlock()
	if not CamlockEnabled then return end
	if not character then return end

	local target = getBestTarget()
	if not target then return end

	local head = target:FindFirstChild("Head")
	local hum = target:FindFirstChildOfClass("Humanoid")
	local camTargetPart = head or getTargetPart(target, AimPart)

	if hum and hum.Health > 0 and camTargetPart then
		local camPos = Camera.CFrame.Position
		local targetPos = camTargetPart.Position
		local desiredCFrame = CFrame.lookAt(camPos, targetPos)
		Camera.CFrame = Camera.CFrame:Lerp(desiredCFrame, math.clamp(Smoothness, 0.01, 1))
	end
end

local function updateEsp()
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= player and p.Character then
			local char = p.Character
			local highlight = char:FindFirstChild("EspHighlight")
			local billboard = char:FindFirstChild("NameTag")
			local hum = char:FindFirstChildOfClass("Humanoid")
			local root = char:FindFirstChild("HumanoidRootPart")
			local head = char:FindFirstChild("Head")

			if EspEnabled and hum and hum.Health > 0 and root then
				if not highlight then
					highlight = Instance.new("Highlight")
					highlight.Name = "EspHighlight"
					highlight.FillTransparency = 1
					highlight.OutlineTransparency = 0.3
					highlight.OutlineColor = Color3.fromRGB(255, 50, 50)
					highlight.Parent = char
				end
				highlight.Enabled = true

				if not billboard then
					billboard = Instance.new("BillboardGui")
					billboard.Name = "NameTag"
					billboard.Size = UDim2.new(0, 120, 0, 35)
					billboard.StudsOffset = Vector3.new(0, 2.5, 0)
					billboard.AlwaysOnTop = true
					billboard.Adornee = head or root
					billboard.Parent = char

					local tl = Instance.new("TextLabel")
					tl.Size = UDim2.new(1, 0, 1, 0)
					tl.BackgroundTransparency = 1
					tl.TextColor3 = Color3.fromRGB(255,255,255)
					tl.TextStrokeTransparency = 0.3
					tl.TextSize = 14
					tl.Font = Enum.Font.GothamBold
					tl.Name = "TagLabel"
					tl.Parent = billboard
				end
				billboard.Enabled = true
				billboard.Adornee = head or root
				local tl = billboard:FindFirstChild("TagLabel")
				if tl then tl.Text = p.Name .. "  [" .. math.floor(hum.Health) .. "HP]" end
			else
				if highlight then highlight.Enabled = false end
				if billboard then billboard.Enabled = false end
			end
		end
	end
end

