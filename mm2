-- ===== AIMBOT & TARGET =====
local function GetTarget()
    local myRole = Cache.Roles[LocalPlayer] or "Innocent"
    if myRole == "Innocent" then return nil end
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local bestTarget, bestDist = nil, Config.Aimbot.FOV
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("Humanoid") then
            local hum = p.Character.Humanoid
            if hum and hum.Health > 0 then
                local pRole = Cache.Roles[p] or "Innocent"
                local isEnemy = false
                if myRole == "Murderer" then isEnemy = (pRole == "Sheriff" or pRole == "Hero" or pRole == "Innocent")
                elseif myRole == "Sheriff" or myRole == "Hero" then isEnemy = (pRole == "Murderer") end
                if isEnemy then
                    local pos, onScreen = Camera:WorldToViewportPoint(p.Character.HumanoidRootPart.Position)
                    if onScreen then local dist = (Vector2.new(pos.X, pos.Y) - center).Magnitude; if dist < bestDist then bestDist = dist; bestTarget = p end end
                end
            end
        end
    end
    return bestTarget
end

local function GetTrackerTarget()
    local myRole = Cache.Roles[LocalPlayer] or "Innocent"
    local targetRole = (myRole == "Murderer") and "Sheriff" or "Murderer"
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local hum = p.Character:FindFirstChild("Humanoid")
            if hum and hum.Health > 0 and (Cache.Roles[p] == targetRole) then return p end
        end
    end
    return nil
end

