        local returnCFrame = myHRP and myHRP.CFrame or originalCFrame
        for i = 1, steps do
            if not myHRP or not myHRP.Parent then break end
            pcall(function() myHRP.CFrame = returnCFrame:Lerp(originalCFrame, i / steps) end)
            task.wait()
        end
