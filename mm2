    local s = Instance.new("Frame")
    s.Size = UDim2.new(0, 1, 1, 0)
    s.BackgroundColor3 = Color3.fromRGB(40, 70, 110)
    s.BorderSizePixel = 0
    s.LayoutOrder = order
    s.Parent = frame
end

local function makeBtn(text, color, order, width)
    local b = Instance.new("TextButton")
    b.Size = UDim2.new(0, width, 1, 0)
    b.BackgroundTransparency = 1
    b.Text = text
    b.TextColor3 = color
    b.TextScaled = true
    b.Font = FONT
    b.LayoutOrder = order
    b.Parent = frame
    return b
end

local btnESP    = makeBtn("[ESP: ON]",  Color3.fromRGB(0, 200, 255),  1, 90)
makeSep(2)
local btnAim    = makeBtn("[Aim: OFF]", Color3.fromRGB(120,120,120),  3, 100)
makeSep(4)
local btnFOV    = makeBtn("[FOV: ON]",  Color3.fromRGB(0, 200, 255),  5, 90)

-- Nút ESP
btnESP.MouseButton1Click:Connect(function()
    on = not on
    btnESP.Text = on and "[ESP: ON]" or "[ESP: OFF]"
    btnESP.TextColor3 = on and Color3.fromRGB(0, 200, 255) or Color3.fromRGB(120,120,120)
end)

-- Nút FOV
btnFOV.MouseButton1Click:Connect(function()
    showFOV = not showFOV
    fovCircle.Visible = showFOV
    btnFOV.Text = showFOV and "[FOV: ON]" or "[FOV: OFF]"
    btnFOV.TextColor3 = showFOV and Color3.fromRGB(0, 200, 255) or Color3.fromRGB(120,120,120)
end)

-- Nút Aimbot (Camlock)
local function updateAimBtn()
    if not aimbotOn then
        btnAim.Text = "[Aim: OFF]"
        btnAim.TextColor3 = Color3.fromRGB(120,120,120)
        return
    end
    btnAim.Text = getMyRole() == "Murderer" and "[Aim: Sheriff]" or "[Aim: Murder]"
    btnAim.TextColor3 = Color3.fromRGB(255,80,80)
end

local function setAimbot(state)
    aimbotOn = state
    if aimbotOn then
        aimbotTarget = getAimbotTarget()
    else
        disableAimbot()
    end
    updateAimBtn()
end
btnAim.MouseButton1Click:Connect(function() setAimbot(not aimbotOn) end)

local labelTimer = 0
RunService.Heartbeat:Connect(function(dt)
    if not aimbotOn then return end
    labelTimer += dt
    if labelTimer >= 0.5 then labelTimer = 0; updateAimBtn() end
end)

-- ===== KEYBIND =====
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.E then setAimbot(not aimbotOn) end
end)

-- ===== DRAG UI =====
local dragging, dragOffX, dragOffY, dragInput
frame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragOffX = input.Position.X - frame.AbsolutePosition.X
        dragOffY = input.Position.Y - frame.AbsolutePosition.Y
        input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
    end
end)
frame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end
end)
UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local ss = workspace.CurrentCamera.ViewportSize
        frame.Position = UDim2.new(0, math.clamp(input.Position.X - dragOffX, 0, ss.X - frame.AbsoluteSize.X), 0, math.clamp(input.Position.Y - dragOffY, 0, ss.Y - frame.AbsoluteSize.Y))
    end
end)

-- ===== SETUP =====
local function setup(p)
    if p == player then return end
    watchTools(p)
    if p.Character then addESP(p) end
    p.CharacterAdded:Connect(function() task.wait(0.5); addESP(p) end)
end

for _, p in pairs(Players:GetPlayers()) do setup(p) end
Players.PlayerAdded:Connect(setup)
Players.PlayerRemoving:Connect(function(p)
    roleCache[p.Name] = nil
    if aimbotTarget == p then aimbotTarget = nil end
    if esp[p] then
        if esp[p].conn then esp[p].conn:Disconnect() end
        if esp[p].hl then esp[p].hl:Destroy() end
        if esp[p].sb then esp[p].sb:Destroy() end
        esp[p] = nil
    end
end)

print("MM2 ESP v5.0 | Aimbot Prediction + FOV | Xóa Hitbox & SA thành công!")
