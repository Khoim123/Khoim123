    -- ===== TARGET =====
    local function UpdateTargetCache()
        local myRole = Cache.Roles[LocalPlayer] or "Innocent"
        local myChar = LocalPlayer.Character
        local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
        TargetCache.Aimbot = nil; TargetCache.Tracker = nil
        if myRole == "Innocent" then return end

        local bestAimDist = Config.Aimbot.FOV
        local targetRole = (myRole == "Murderer") and "Sheriff" or "Murderer"

        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                local char = p.Character
                local hrp = char:FindFirstChild("HumanoidRootPart")
                local hum = char:FindFirstChild("Humanoid")
                if hrp and hum and hum.Health > 0 then
                    local pRole = Cache.Roles[p] or "Innocent"
                    local isEnemy = false
                    if myRole == "Murderer" then isEnemy = (pRole == "Sheriff" or pRole == "Hero" or pRole == "Innocent")
                    elseif myRole == "Sheriff" or myRole == "Hero" then isEnemy = (pRole == "Murderer") end
                    
                    if isEnemy then
                        local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
                        if onScreen then
                            local dist = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                            if dist < bestAimDist then bestAimDist = dist; TargetCache.Aimbot = p end
                        end
                    end
                    if pRole == targetRole and not TargetCache.Tracker then TargetCache.Tracker = p end
                end
            end
        end
    end

    task.spawn(function() while task.wait(0.1) do if State.ShuttingDown then break end; UpdateTargetCache() end end)

