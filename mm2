    local isGrabbing = false

    SetupMobileButton(GrabButton, function()
        if isGrabbing then return end
        if not Cache.GunDropObj or not Cache.GunDropObj.Parent then return end
        local myChar = LocalPlayer.Character
        if not myChar then return end
        local myHRP = myChar:FindFirstChild("HumanoidRootPart")
        if not myHRP then return end

        -- ANTI-CHEAT: Kiểm tra khoảng cách > 1000m thì block
        local gunDist = (myHRP.Position - Cache.GunDropObj.Position).Magnitude
        if gunDist > Config.GunCollect.MaxGrabDistance then
            GrabLabel.Text = "TOO FAR"
            task.spawn(function()
                task.wait(1.5)
                if GrabLabel then GrabLabel.Text = "GRAB" end
            end)
            return
        end

        isGrabbing = true
        GrabLabel.Text = "FLY..."

        local gunPos = Cache.GunDropObj.Position
        local originalCFrame = myHRP.CFrame
        local distance = (myHRP.Position - gunPos).Magnitude
        local steps = math.clamp(math.floor(distance / math.max(Config.GunCollect.Speed, 100) * 60), 10, 150)

        task.spawn(function()
            for i = 1, steps do
                if not myHRP or not myHRP.Parent then break end
                pcall(function() myHRP.CFrame = originalCFrame:Lerp(CFrame.new(gunPos), i / steps) end)
                task.wait()
            end
            task.wait(0.3)
            local returnCFrame = myHRP and myHRP.CFrame or originalCFrame
            for i = 1, steps do
                if not myHRP or not myHRP.Parent then break end
                pcall(function() myHRP.CFrame = returnCFrame:Lerp(originalCFrame, i / steps) end)
                task.wait()
            end
            GrabLabel.Text = "GRAB"
            isGrabbing = false
        end)
    end)

    -- ===== REACH =====
    local function HandleReach()
        local myChar = LocalPlayer.Character
        if not myChar then ReachCircle.Visible = false; return end
        local tool = myChar:FindFirstChildWhichIsA("Tool")
        local isHoldingKnife = tool and (tool:FindFirstChild("KnifeScript") or string.find(string.lower(tool.Name), "knife"))
        if isHoldingKnife and Config.Reach.Enabled then
            local handle = tool:FindFirstChild("Handle")
            if handle and handle:IsA("BasePart") then
                if Cache.OriginalHandleTool ~= tool then
                    Cache.OriginalHandleSize = handle.Size; Cache.OriginalHandleTool = tool
                end
                local m = Config.Reach.Radius / 3
                handle.Size = Cache.OriginalHandleSize * Vector3.new(m,m,m)
                handle.Transparency = 0.8; handle.CanCollide = false; handle.Massless = true
                
                local myHRP = myChar:FindFirstChild("HumanoidRootPart")
                if myHRP then
                    ReachCircle.Visible = true
                    ReachCircle.Radius = Config.Reach.Radius * (Camera.ViewportSize.Y / (2 * math.tan(Camera.FieldOfView * math.rad(0.5)) * (Camera.CFrame.Position - myHRP.Position).Magnitude))
                    local screenPos, onScreen = Camera:WorldToViewportPoint(myHRP.Position - Vector3.new(0, 2.5, 0))
                    if onScreen then
                        ReachCircle.Position = Vector2.new(screenPos.X, screenPos.Y)
                    else
                        ReachCircle.Visible = false
                    end
                end
            end
        else
            if Cache.OriginalHandleTool and Cache.OriginalHandleSize then
                local oldHandle = Cache.OriginalHandleTool:FindFirstChild("Handle")
                if oldHandle and oldHandle:IsA("BasePart") then
                    oldHandle.Size = Cache.OriginalHandleSize
                    oldHandle.Transparency = 0; oldHandle.CanCollide = true; oldHandle.Massless = false
                end
            end
            Cache.OriginalHandleSize = nil; Cache.OriginalHandleTool = nil; ReachCircle.Visible = false
        end
    end

    -- ===== MAIN LOOP =====
    task.spawn(function()
        while task.wait(0.1) do
            if State.ShuttingDown then break end
            local camPos = Camera.CFrame.Position
            local myHRP = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            HandleReach()
            
            -- Cập nhật ESP Người chơi
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Parent then
                    local esp = Cache.ESPs[p]; local char = p.Character
                    local hrp = char and char:FindFirstChild("HumanoidRootPart")
                    if esp then
                        if not esp.Char or not esp.Char.Parent or not esp.HRP or not esp.HRP.Parent then
                            pcall(function() if esp.HL then esp.HL:Destroy() end; if esp.Bill then esp.Bill:Destroy() end end)
                            Cache.ESPs[p] = nil; esp = nil
                        end
                    end
                    if not esp and char and hrp then
                        local hl = Instance.new("Highlight")
                        hl.FillTransparency = 0.6; hl.OutlineTransparency = 0.1
                        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop; hl.Parent = char
                        local bill = Instance.new("BillboardGui")
                        bill.Size = UDim2.new(0,150,0,40); bill.StudsOffset = Vector3.new(0,3,0)
                        bill.AlwaysOnTop = true; bill.Parent = hrp
                        local txt = Instance.new("TextLabel")
                        txt.Size = UDim2.new(1,0,1,0); txt.BackgroundTransparency = 1
                        txt.Font = Enum.Font.GothamBold; txt.TextSize = 13; txt.TextWrapped = true
                        txt.TextStrokeTransparency = 0.2; txt.Parent = bill
                        Cache.ESPs[p] = { Char = char, HRP = hrp, HL = hl, Bill = bill, Txt = txt }
                        esp = Cache.ESPs[p]
                    end
                    if esp and esp.HL and esp.HL.Parent and esp.Bill and esp.Bill.Parent and esp.HRP and esp.HRP.Parent then
                        local dist = (camPos - esp.HRP.Position).Magnitude
                        local role = Cache.Roles[p] or "Innocent"
                        if Config.ESP.Enabled and dist < Config.ESP.MaxDistance then
                            local color = role=="Murderer" and Color3.fromRGB(255,50,50) or role=="Sheriff" and Color3.fromRGB(50,100,255) or role=="Hero" and Color3.fromRGB(255,215,0) or Color3.fromRGB(0,255,0)
                            esp.HL.Enabled = true; esp.HL.FillColor = color; esp.HL.OutlineColor = color
                            esp.Bill.Enabled = true
                            esp.Txt.Text = p.DisplayName.."\n["..role.."] "..math.floor(dist).."m"
                            esp.Txt.TextColor3 = color
                        else
                            esp.HL.Enabled = false; esp.Bill.Enabled = false
                        end
                    end
                end
            end
            
            -- CẬP NHẬT ESP SÚNG (Thêm logic ẩn nếu > 1000m)
            if Config.ESP.Enabled and Cache.GunDropObj and Cache.GunDropObj.Parent and Cache.GunDropESP and Cache.GunDropESP.HL and Cache.GunDropESP.Bill and myHRP then
                local gunDist = (myHRP.Position - Cache.GunDropObj.Position).Magnitude
                if gunDist <= Config.GunCollect.MaxGrabDistance then
                    Cache.GunDropESP.HL.Enabled = true
                    Cache.GunDropESP.Bill.Enabled = true
                    Cache.GunDropESP.Txt.Text = "GUN DROP\n"..math.floor(gunDist).."m"
                else
                    -- ANTI-CHEAT: Ẩn ESP súng nếu xa quá 1000m
                    Cache.GunDropESP.HL.Enabled = false
                    Cache.GunDropESP.Bill.Enabled = false
                end
            end
        end
    end)

    -- ===== RENDER LOOP =====
    RunService.RenderStepped:Connect(function(dt)
        if State.ShuttingDown then return end

        if Config.Aimbot.Enabled then
            local target = TargetCache.Aimbot
            if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
                local tHrp = target.Character.HumanoidRootPart
                local tPos = tHrp.Position + (tHrp.Velocity * Config.Aimbot.Prediction)
                Camera.CFrame = Camera.CFrame:Lerp(CFrame.lookAt(Camera.CFrame.Position, tPos), Config.Aimbot.Smoothing)
            end
        end

        if TrackerSupported and Config.Tracker.Enabled then
            local tTarget = TargetCache.Tracker
            if tTarget and tTarget.Character and tTarget.Character:FindFirstChild("HumanoidRootPart") then
                local pos, onScreen = Camera:WorldToViewportPoint(tTarget.Character.HumanoidRootPart.Position)
                if onScreen then
                    TrackerLine.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
                    TrackerLine.To = Vector2.new(pos.X, pos.Y)
                    TrackerLine.Visible = true
                else TrackerLine.Visible = false end
            else TrackerLine.Visible = false end
        elseif TrackerSupported then TrackerLine.Visible = false end

        local aimTarget = TargetCache.Aimbot
        local targetInfo = aimTarget and (aimTarget.Name.." [".. (Cache.Roles[aimTarget] or "?").."]") or "None"
        HookLabel.Text = "Stealth: OK | Aim: "..targetInfo
    end)
end

pcall(MM2_Stealth_Init)