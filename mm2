--[[
    MM2 ESP v5.0 - ESP + Predictive Aimbot + FOV
    Đã xoá Hitbox & Silent Aim theo yêu cầu.
    Thêm Aimbot có tính toán hướng di chuyển (Prediction) để dễ trúng mục tiêu đang chạy.
    - Phím: E = Bật/Tắt Aimbot
]]

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local Camera = workspace.CurrentCamera

local player = Players.LocalPlayer
local esp = {}
local roleCache = {}
local on = true

-- Cài đặt Aimbot (Camlock)
local aimbotOn = false
local aimbotTarget = nil
local SMOOTHNESS = 1 -- Độ mượt của Camlock (0.1 đến 1)
local PREDICTION_SPEED = 120 -- Tốc độ bay của súng/dao (chỉnh cao hơn nếu ngắm bị lố về phía trước)

-- Vòng FOV
local showFOV = true
local fovRadius = 150
local fovCircle = Drawing.new("Circle")
fovCircle.Visible = showFOV
fovCircle.Radius = fovRadius
fovCircle.Color = Color3.fromRGB(255, 255, 255)
fovCircle.Thickness = 1.5
fovCircle.Filled = false
fovCircle.Position = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

local FONT = Enum.Font.GothamBold

local colors = {
    Murderer = Color3.fromRGB(255, 0, 0),
    Sheriff  = Color3.fromRGB(0, 100, 255),
    Hero     = Color3.fromRGB(255, 215, 0),
    Innocent = Color3.fromRGB(0, 255, 100),
}

-- Cập nhật FOV Circle theo màn hình
RunService.RenderStepped:Connect(function()
    if fovCircle then
        fovCircle.Position = UserInputService:GetMouseLocation()
    end
end)

-- ===== ROLE DETECTION =====
local function getRoleFromTool(toolName)
    local n = toolName:lower()
    if n:find("knife") or n:find("blade") or n:find("dagger") then return "Murderer" end
    if n:find("gun") or n:find("revolver") or n:find("pistol") then return "Sheriff" end
    if n:find("hero") then return "Hero" end
    return nil
end

local function scanTools(p)
    for _, c in pairs({p.Character, p:FindFirstChild("Backpack")}) do
        if c then
            for _, t in pairs(c:GetChildren()) do
                if t:IsA("Tool") then
                    local role = getRoleFromTool(t.Name)
                    if role then roleCache[p.Name] = role; return end
                end
            end
        end
    end
end

local function watchTools(p)
    local function onToolAdded(t)
        if not t:IsA("Tool") then return end
        local role = getRoleFromTool(t.Name)
        if role then roleCache[p.Name] = role end
    end
    local bp = p:FindFirstChild("Backpack")
    if bp then bp.ChildAdded:Connect(onToolAdded) end
    local function watchChar(char)
        char.ChildAdded:Connect(onToolAdded)
        char.AncestryChanged:Connect(function()
            if not char.Parent then roleCache[p.Name] = nil end
        end)
    end
    if p.Character then watchChar(p.Character) end
    p.CharacterAdded:Connect(function(char)
        roleCache[p.Name] = nil
        task.wait(0.1)
        watchChar(char)
        local newBp = p:WaitForChild("Backpack", 5)
        if newBp then newBp.ChildAdded:Connect(onToolAdded) end
    end)
end

local function getRole(p)
    scanTools(p)
    return roleCache[p.Name] or "Innocent"
end

local function getMyRole()
    return getRole(player)
end

local function getDistance(p)
    local mc, tc = player.Character, p.Character
    if not mc or not tc then return math.huge end
    local mr, tr = mc:FindFirstChild("HumanoidRootPart"), tc:FindFirstChild("HumanoidRootPart")
    if not mr or not tr then return math.huge end
    return (mr.Position - tr.Position).Magnitude
end

-- ===== PREDICTIVE AIMBOT =====
local function getAimbotTarget()
    local myRole = getMyRole()
    local closestDist = fovRadius
    local target = nil
    local mousePos = UserInputService:GetMouseLocation()

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local role = getRole(p)
            local match = (myRole == "Murderer" and (role == "Sheriff" or role == "Hero")) or (role == "Murderer")
            
            if match then
                local hrp = p.Character.HumanoidRootPart
                local screenPos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
                if onScreen then
                    local dist = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                    if dist < closestDist then
                        closestDist = dist
                        target = p
                    end
                end
            end
        end
    end
    return target
end

local function isValidTarget(p)
    if not p or not p.Parent or not p.Character then return false end
    local myRole = getMyRole()
    local role = getRole(p)
    return (myRole == "Murderer" and (role == "Sheriff" or role == "Hero")) or (role == "Murderer")
end

RunService:BindToRenderStep("MM2_Aimbot", Enum.RenderPriority.Camera.Value + 1, function()
    if not aimbotOn then return end
    if not isValidTarget(aimbotTarget) then aimbotTarget = getAimbotTarget() end
    
    if aimbotTarget and aimbotTarget.Character then
        local tp = aimbotTarget.Character:FindFirstChild("HumanoidRootPart")
        if tp then 
            -- Tính toán vị trí dự đoán (Prediction)
            local dist = (Camera.CFrame.Position - tp.Position).Magnitude
            local predictionTime = dist / PREDICTION_SPEED
            local predictedPos = tp.Position + (tp.Velocity * predictionTime)
            
            -- Camlock mượt mà vào vị trí dự đoán
            local targetCFrame = CFrame.lookAt(Camera.CFrame.Position, predictedPos)
            Camera.CFrame = Camera.CFrame:Lerp(targetCFrame, SMOOTHNESS)
        end
    end
end)

local function disableAimbot()
    aimbotOn = false
    aimbotTarget = nil
end

-- ===== ESP =====
local function addESP(p)
    if p == player then return end
    if esp[p] then
        if esp[p].conn then esp[p].conn:Disconnect() end
        if esp[p].hl   then esp[p].hl:Destroy() end
        if esp[p].sb   then esp[p].sb:Destroy() end
        esp[p] = nil
    end

    local char = p.Character or p.CharacterAdded:Wait()
    local head = char:WaitForChild("Head", 5)
    local hrp = char:WaitForChild("HumanoidRootPart", 5)
    if not head or not hrp then return end

    local hl = Instance.new("Highlight")
    hl.FillTransparency = 0.5
    hl.OutlineTransparency = 0
    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    hl.Parent = char

    local sb = Instance.new("SelectionBox")
    sb.Adornee = hrp
    sb.LineThickness = 0.04
    sb.SurfaceTransparency = 0.85
    sb.Visible = false
    sb.Parent = Camera

    local bill = Instance.new("BillboardGui")
    bill.Adornee = head
    bill.Size = UDim2.new(0, 130, 0, 55)
    bill.StudsOffset = Vector3.new(0, 3, 0)
    bill.AlwaysOnTop = true
    bill.Parent = head

    local txt = Instance.new("TextLabel")
    txt.Size = UDim2.new(1, 0, 1, 0)
    txt.BackgroundTransparency = 1
    txt.TextScaled = true
    txt.Font = FONT
    txt.TextStrokeTransparency = 0.5
    txt.Parent = bill

    local conn
    conn = RunService.Heartbeat:Connect(function()
        if not p.Parent or not char.Parent or not head.Parent then
            conn:Disconnect(); hl:Destroy(); sb:Destroy(); esp[p] = nil; return
        end
        local role = getRole(p)
        local c = colors[role] or Color3.fromRGB(150, 150, 150)
        local dist = math.floor(getDistance(p))
        local isSpecial = role == "Murderer" or role == "Sheriff" or role == "Hero"

        if not on then
            hl.Enabled = false; txt.Visible = false; sb.Visible = false; return
        end
        
        hl.Enabled = true; txt.Visible = true
        if role == "Murderer" then
            local f = math.sin(tick() * 8) * 0.3 + 0.7
            hl.FillColor = Color3.new(1, f * 0.2, f * 0.2)
            hl.OutlineColor = Color3.new(1, 0, 0)
        else
            hl.FillColor = c; hl.OutlineColor = c
        end
        txt.TextColor3 = c
        txt.Text = p.DisplayName .. "\n[" .. role .. "]\n" .. dist .. "m"

        sb.Visible = isSpecial
        if sb.Visible then sb.Color3 = c; sb.SurfaceColor3 = c end
    end)

    esp[p] = {hl = hl, sb = sb, conn = conn}
end

-- ===== GUI =====
if game.CoreGui:FindFirstChild("MM2_ESP") then
    game.CoreGui.MM2_ESP:Destroy()
end

local gui = Instance.new("ScreenGui")
gui.Name = "MM2_ESP"
