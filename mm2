-- ===== UTILITIES =====
local function SmoothDamp(current, target, smoothTime, dt)
    local speed = 1 / smoothTime
    local diff = (target - current) * math.min(speed * dt, 1)
    return current + diff
end

local function WorldToScreen(pos)
    local vec, onScreen = Camera:WorldToViewportPoint(pos)
    return Vector2.new(vec.X, vec.Y), onScreen, vec.Z
end

local function GetRoleFromTool(name)
    local n = string.lower(name)
    if n:find("knife") or n:find("blade") or n:find("dagger") then return "Murderer" end
    if n:find("gun") or n:find("revolver") or n:find("pistol") then return "Sheriff" end
    if n:find("hero") then return "Hero" end
    return "Innocent"
end

local function UpdateRoleCache(player)
    local char = player.Character
    if not char then return end
    
    -- Ưu tiên kiểm tra tool đang cầm
    local currentTool = char:FindFirstChildWhichIsA("Tool")
    if currentTool then
        Cache.Roles[player.Name] = GetRoleFromTool(currentTool.Name)
        return    end
    
    -- Kiểm tra Backpack
    local backpack = player:FindFirstChild("Backpack")
    if backpack then
        for _, tool in pairs(backpack:GetChildren()) do
            if tool:IsA("Tool") then
                Cache.Roles[player.Name] = GetRoleFromTool(tool.Name)
                return
            end
        end
    end
    Cache.Roles[player.Name] = "Innocent"
end

local function GetPlayerRole(player)
    return Cache.Roles[player.Name] or "Innocent"
end

local function GetMyRole()
    return GetPlayerRole(LocalPlayer)
end

-- ===== ESP SYSTEM =====
local function CreateESP(player)
    if player == LocalPlayer or Cache.ESPs[player] then return end
    
    local char = player.Character
    if not char then return end
    
    local head = char:WaitForChild("Head", 5)
    local hrp = char:WaitForChild("HumanoidRootPart", 5)
    if not head or not hrp then return end
    
    local hl = Instance.new("Highlight")
    hl.FillTransparency = 0.6
    hl.OutlineTransparency = 0.2
    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    hl.Parent = char
    
    local tracer = Instance.new("Beam")
    tracer.Enabled = false
    tracer.FaceCamera = true
    tracer.Width0 = 0.03
    tracer.Width1 = 0.03
    tracer.Color = ColorSequence.new(Color3.new(1,1,1))
    tracer.Transparency = NumberSequence.new(0.4)
    tracer.Parent = hrp
    
    local attach0 = Instance.new("Attachment")    attach0.Position = Vector3.new(0, 2.5, 0)
    attach0.Parent = head
    
    local attach1 = Instance.new("Attachment")
    attach1.Position = Vector3.new(0, 0, 0)
    attach1.Parent = hrp
    
    tracer.Attachment0 = attach0
    tracer.Attachment1 = attach1
    
    local bill = Instance.new("BillboardGui")
    bill.Adornee = head
    bill.Size = UDim2.new(0, 120, 0, 40)
    bill.StudsOffset = Vector3.new(0, 2.5, 0)
    bill.AlwaysOnTop = true
    bill.Parent = head
    
    local txt = Instance.new("TextLabel")
    txt.Size = UDim2.new(1, 0, 1, 0)
    txt.BackgroundTransparency = 1
    txt.TextScaled = true
    txt.Font = Enum.Font.GothamBold
    txt.TextStrokeTransparency = 0.4
    txt.Parent = bill
    
    Cache.ESPs[player] = {
        Player = player,
        Char = char,
        Head = head,
        HRP = hrp,
        HL = hl,
        Tracer = tracer,
        Bill = bill,
        Txt = txt,
        Attachments = {attach0, attach1}
    }
end

-- ===== AIMBOT SYSTEM =====
local function IsValidTarget(player)
    if not player or player == LocalPlayer or not player.Character then return false end
    local myRole = GetMyRole()
    local targetRole = GetPlayerRole(player)
    
    if Config.Aimbot.TargetPriority == "Murder" then
        return targetRole == "Murderer"
    elseif Config.Aimbot.TargetPriority == "Sheriff" then
        return targetRole == "Sheriff" or targetRole == "Hero"
    else
        return (myRole == "Murderer" and (targetRole == "Sheriff" or targetRole == "Hero")) or targetRole == "Murderer"    end
end

local function FindBestTarget()
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local bestPlayer, bestDist = nil, Config.Aimbot.FOV
    
    for _, p in ipairs(Players:GetPlayers()) do
        if IsValidTarget(p) and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local hrp = p.Character.HumanoidRootPart
            local screenPos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
            if onScreen then
                local distToCenter = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
                if distToCenter < bestDist then
                    bestDist = distToCenter
                    bestPlayer = p
                end
            end
        end
    end
    return bestPlayer
end

RunService:BindToRenderStep("MM2_Aimbot", Enum.RenderPriority.Camera.Value + 1, function()
    if not Config.Aimbot.Enabled or not State.AimbotActive then
        State.CurrentTarget = nil
        return
    end
    
    if not IsValidTarget(State.CurrentTarget) then
        State.CurrentTarget = FindBestTarget()
        State.LastTargetSwitch = tick()
    end
    
    if State.CurrentTarget and State.CurrentTarget.Character then
        local hrp = State.CurrentTarget.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            local dist = (Camera.CFrame.Position - hrp.Position).Magnitude
            local predictTime = dist * Config.Aimbot.Prediction
            local targetPos = hrp.Position + (hrp.Velocity * predictTime)
            
            local targetCF = CFrame.lookAt(Camera.CFrame.Position, targetPos)
            Camera.CFrame = Camera.CFrame:Lerp(targetCF, Config.Aimbot.Smoothing)
        end
    end
end)

