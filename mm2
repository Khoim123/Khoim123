-- ===== ROLE LOGIC (POLLING METHOD) =====
local function GetRoleFromTool(tool)
    if not tool then return nil end
    if tool:FindFirstChild("KnifeScript") then return "Murderer" end
    if tool:FindFirstChild("GunScript") then return "Sheriff" end
    local n = string.lower(tool.Name)
    if n:find("knife") or n:find("blade") or n:find("dagger") or n:find("axe") or n:find("scythe") or n:find("claw") then return "Murderer" end
    if n:find("gun") or n:find("revolver") or n:find("pistol") or n:find("blaster") then return "Sheriff" end
    return nil
end

local function UpdateRole(player)
    if not player or not player.Parent then return end
    local char = player.Character
    if char then
        local charTool = char:FindFirstChildWhichIsA("Tool")
        if charTool then local role = GetRoleFromTool(charTool); if role then Cache.Roles[player] = role; return end end
    end
    local bp = player:FindFirstChild("Backpack")
    if bp then
        for _, bpTool in ipairs(bp:GetChildren()) do
            if bpTool:IsA("Tool") then local role = GetRoleFromTool(bpTool); if role then Cache.Roles[player] = role; return end end
        end
    end
    local rsPlayers = ReplicatedStorage:FindFirstChild("Players")
    if rsPlayers then
        local pData = rsPlayers:FindFirstChild(player.Name)
        if pData then
            local roleObj = pData:FindFirstChild("Role")
            if roleObj and roleObj:IsA("StringValue") then
                local val = roleObj.Value
                if val == "Murderer" or val == "Sheriff" or val == "Hero" then Cache.Roles[player] = val; return end
            end
        end
    end
    Cache.Roles[player] = "Innocent"
end

task.spawn(function()
    while task.wait(0.5) do
        for _, p in ipairs(Players:GetPlayers()) do
            if p.Parent then UpdateRole(p) end
        end
    end
end)

