    local function CreateSlider(lbl, tbl, key, min, max)
        local container = Instance.new("Frame")
        container.Size = UDim2.new(1,0,0,35); container.BackgroundTransparency = 1
        container.Parent = ScrollFrame; container.LayoutOrder = 3
        local l = Instance.new("TextLabel")
        l.Size = UDim2.new(1,0,0,15); l.BackgroundTransparency = 1
        l.Text = lbl..": "..string.format("%.2f",tbl[key])
        l.Font = Enum.Font.Gotham; l.TextSize = 11; l.TextColor3 = Color3.fromRGB(200,200,200)
        l.TextXAlignment = Enum.TextXAlignment.Left; l.Parent = container
        local b = Instance.new("TextButton")
        b.Size = UDim2.new(1,0,0,8); b.Position = UDim2.new(0,0,0,20)
        b.BackgroundColor3 = Color3.fromRGB(40,40,60); b.Text = ""; b.BorderSizePixel = 0
        b.AutoButtonColor = false; b.Selectable = false; b.Parent = container
        Instance.new("UICorner", b).CornerRadius = UDim.new(1,0)
        local f = Instance.new("Frame"); f.BackgroundColor3 = Theme.On_BG; f.BorderSizePixel = 0
        f.Parent = b; Instance.new("UICorner", f).CornerRadius = UDim.new(1,0)
        local function update()
            local p = (tbl[key]-min)/(max-min)
            f.Size = UDim2.new(math.clamp(p,0,1),0,1,0)
            l.Text = lbl..": "..string.format("%.2f",tbl[key])
        end
        local sliderDragging = false; local sliderTouchInput = nil
        b.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
                sliderDragging = true; sliderTouchInput = input
                local p = math.clamp((input.Position.X - b.AbsolutePosition.X) / b.AbsoluteSize.X, 0, 1)
                tbl[key] = min + (p * (max-min)); update()
            end
        end)
        UserInputService.InputChanged:Connect(function(input)
            if sliderDragging and (input == sliderTouchInput or input.UserInputType == Enum.UserInputType.MouseMovement) then
                local p = math.clamp((input.Position.X - b.AbsolutePosition.X) / b.AbsoluteSize.X, 0, 1)
                tbl[key] = min + (p * (max-min)); update()
            end
        end)
        UserInputService.InputEnded:Connect(function(input)
            if input == sliderTouchInput then sliderDragging = false; sliderTouchInput = nil end
        end)
        task.defer(update)
    end

