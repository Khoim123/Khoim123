-- ===== PLAYER ESP =====
local function CreateESP(player)
    if player == LocalPlayer or Cache.ESPs[player] then return end
    local char = player.Character
    if not char then return end
    local hrp = char:WaitForChild("HumanoidRootPart", 3)
    if not hrp then return end
    local hl = Instance.new("Highlight")
    hl.FillTransparency = 0.6; hl.OutlineTransparency = 0.1; hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop; hl.Parent = char
    local bill = Instance.new("BillboardGui")
    bill.Size = UDim2.new(0, 150, 0, 40); bill.StudsOffset = Vector3.new(0, 3, 0); bill.AlwaysOnTop = true; bill.Parent = char:WaitForChild("Head", 3)
    local txt = Instance.new("TextLabel")
    txt.Size = UDim2.new(1, 0, 1, 0); txt.BackgroundTransparency = 1; txt.Font = Enum.Font.GothamBold; txt.TextScaled = true; txt.TextStrokeTransparency = 0.2; txt.Parent = bill
    Cache.ESPs[player] = { Char = char, HRP = hrp, HL = hl, Bill = bill, Txt = txt }
end

RunService.RenderStepped:Connect(function()
    local camPos = Camera.CFrame.Position
    if Config.Aimbot.Enabled then
        State.AimbotTarget = GetTarget()
        if State.AimbotTarget and State.AimbotTarget.Character then
            local targetHrp = State.AimbotTarget.Character:FindFirstChild("HumanoidRootPart")
            if targetHrp then
                local tPos = targetHrp.Position + (targetHrp.Velocity * Config.Aimbot.Prediction)
                Camera.CFrame = Camera.CFrame:Lerp(CFrame.lookAt(camPos, tPos), Config.Aimbot.Smoothing)
            end
        end
    end
    for _, p in ipairs(Players:GetPlayers()) do
        if p == LocalPlayer then continue end
        local esp = Cache.ESPs[p]
        if esp and esp.Char and esp.Char.Parent then
            local dist = (camPos - esp.HRP.Position).Magnitude
            local role = Cache.Roles[p] or "Innocent"
            if Config.ESP.Enabled and dist < Config.ESP.MaxDistance then
                local color = role == "Murderer" and Color3.fromRGB(255, 50, 50) or role == "Sheriff" and Color3.fromRGB(50, 100, 255) or Color3.fromRGB(0, 255, 0)
                esp.HL.Enabled = true; esp.HL.FillColor = color; esp.HL.OutlineColor = color
                esp.Bill.Enabled = true; esp.Txt.Text = p.DisplayName .. "\n[" .. role .. "] " .. math.floor(dist) .. "m"; esp.Txt.TextColor3 = color
            else
                esp.HL.Enabled = false; esp.Bill.Enabled = false
            end
        elseif esp then
            if esp.HL then esp.HL:Destroy() end
            if esp.Bill then esp.Bill:Destroy() end
            Cache.ESPs[p] = nil
        end
    end
end)

