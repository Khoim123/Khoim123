RunService.RenderStepped:Connect(function()
    if State.ShuttingDown then return end
    local camPos = Camera.CFrame.Position
    local myHRP = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")

    if Config.Aimbot.Enabled then
        local target = GetTarget()
        if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
            local tHrp = target.Character.HumanoidRootPart; local tPos = tHrp.Position + (tHrp.Velocity * Config.Aimbot.Prediction)
            Camera.CFrame = Camera.CFrame:Lerp(CFrame.lookAt(camPos, tPos), Config.Aimbot.Smoothing)
        end
    end

    if TrackerSupported and Config.Tracker.Enabled then
        local tTarget = GetTrackerTarget()
        if tTarget and tTarget.Character and tTarget.Character:FindFirstChild("HumanoidRootPart") then
            local pos, onScreen = Camera:WorldToViewportPoint(tTarget.Character.HumanoidRootPart.Position)
            if onScreen then TrackerLine.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y); TrackerLine.To = Vector2.new(pos.X, pos.Y); TrackerLine.Visible = true else TrackerLine.Visible = false end
        else TrackerLine.Visible = false end
    elseif TrackerSupported then TrackerLine.Visible = false end

    HandleReach()

    -- TỰ ĐỘNG TẠI VÀ SỬA ESP NẾU BỊ LỠ HOẶC MẤT
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Parent then
            local esp = Cache.ESPs[p]
            local char = p.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")

            -- Nếu đã có ESP, kiểm tra xem Character có bị hỏng/xóa không
            if esp then
                if not esp.Char or not esp.Char.Parent or not esp.HRP or not esp.HRP.Parent then
                    pcall(function() if esp.HL then esp.HL:Destroy() end; if esp.Bill then esp.Bill:Destroy() end end)
                    Cache.ESPs[p] = nil
                    esp = nil -- Đặt lại nil để tạo lại ở dưới
                end
            end

            -- Nếu chưa có ESP, và người chơi đã có Character + HRP -> Tạo ngay!
            if not esp and char and hrp then
                local hl = Instance.new("Highlight"); hl.FillTransparency = 0.6; hl.OutlineTransparency = 0.1; hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop; hl.Parent = char
                local bill = Instance.new("BillboardGui"); bill.Size = UDim2.new(0, 150, 0, 40); bill.StudsOffset = Vector3.new(0, 3, 0); bill.AlwaysOnTop = true; bill.Parent = hrp
                local txt = Instance.new("TextLabel"); txt.Size = UDim2.new(1,0,1,0); txt.BackgroundTransparency = 1; txt.Font = Enum.Font.GothamBold; txt.TextSize = 13; txt.TextWrapped = true; txt.TextStrokeTransparency = 0.2; txt.Parent = bill
                Cache.ESPs[p] = { Char = char, HRP = hrp, HL = hl, Bill = bill, Txt = txt }
                esp = Cache.ESPs[p]
            end

            -- Cập nhật ESP (Màu sắc, khoảng cách)
            if esp and esp.HL and esp.HL.Parent and esp.Bill and esp.Bill.Parent then
                local dist = (camPos - esp.HRP.Position).Magnitude
                local role = Cache.Roles[p] or "Innocent"
                if Config.ESP.Enabled and dist < Config.ESP.MaxDistance then
                    local color = role=="Murderer" and Color3.fromRGB(255,50,50) or role=="Sheriff" and Color3.fromRGB(50,100,255) or role=="Hero" and Color3.fromRGB(255,215,0) or Color3.fromRGB(0,255,0)
                    esp.HL.Enabled = true; esp.HL.FillColor = color; esp.HL.OutlineColor = color
                    esp.Bill.Enabled = true; esp.Txt.Text = p.DisplayName.."\n["..role.."] "..math.floor(dist).."m"; esp.Txt.TextColor3 = color
                else
                    esp.HL.Enabled = false; esp.Bill.Enabled = false
                end
            end
        end
    end

    if Config.ESP.Enabled and Cache.GunDropObj and Cache.GunDropObj.Parent and Cache.GunDropESP and Cache.GunDropESP.Txt and myHRP then
        local dist = math.floor((myHRP.Position - Cache.GunDropObj.Position).Magnitude)
        Cache.GunDropESP.Txt.Text = "GUN DROP\n" .. dist .. "m"
    end
end)