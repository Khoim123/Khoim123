-- ===== TARGET =====
local function UpdateTargetCache()
    local myRole = Cache.Roles[LocalPlayer] or "Innocent"
    local myChar = LocalPlayer.Character
    local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    TargetCache.Aimbot = nil; TargetCache.Silent = nil; TargetCache.Tracker = nil
    if myRole == "Innocent" then return end

    local bestAimDist = Config.Aimbot.FOV
    local bestSilentDist = 9999
    local maxSilentRange = 20
    local myCurrentTool = myChar and myChar:FindFirstChildWhichIsA("Tool")
    if myCurrentTool and (myCurrentTool:FindFirstChild("GunScript") or string.lower(myCurrentTool.Name):find("gun")) then
        maxSilentRange = 300
    end
    local targetRole = (myRole == "Murderer") and "Sheriff" or "Murderer"

    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local char = p.Character
            local hrp = char:FindFirstChild("HumanoidRootPart")
            local hum = char:FindFirstChild("Humanoid")
            if hrp and hum and hum.Health > 0 then
                local pRole = Cache.Roles[p] or "Innocent"
                local isEnemy = false
                if myRole == "Murderer" then
                    isEnemy = (pRole == "Sheriff" or pRole == "Hero" or pRole == "Innocent")
                elseif myRole == "Sheriff" or myRole == "Hero" then
                    isEnemy = (pRole == "Murderer")
                end
                if isEnemy then
                    local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
                    if onScreen then
                        local dist = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                        if dist < bestAimDist then bestAimDist = dist; TargetCache.Aimbot = p end
                    end
                    if myHRP then
                        local dist3D = (myHRP.Position - hrp.Position).Magnitude
                        if dist3D < maxSilentRange and dist3D < bestSilentDist then
                            bestSilentDist = dist3D; TargetCache.Silent = p
                        end
                    end
                end
                if pRole == targetRole and not TargetCache.Tracker then TargetCache.Tracker = p end
            end
        end
    end
end

task.spawn(function()
    while task.wait(0.1) do
        if State.ShuttingDown then break end
        UpdateTargetCache()
    end
end)

-- ===== SILENT AIM - __namecall CHỈ SỬA CFRAME =====
local function InstallSilentAimHook()
    if SilentAimState.HookInstalled then return true end
    local hasHook = false
    pcall(function() hasHook = (hookmetamethod ~= nil) and (getnamecallmethod ~= nil) end)
    if not hasHook then return false end

    local cachedShootRemote = nil

    SilentAimState.OldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()
        if method == "FireServer" and Config.SilentAim.Enabled then
            local isShoot = false
            if cachedShootRemote and self == cachedShootRemote then
                isShoot = true
            else
                local parent = self.Parent
                while parent and not isShoot do
                    if parent:IsA("Tool") then
                        if parent:FindFirstChild("GunScript") or parent.Name:lower():find("gun") then
                            isShoot = true; cachedShootRemote = self
                        end
                        break
                    end
                    parent = parent.Parent
                end
            end
            if isShoot then
                local target = TargetCache.Silent
                if target and target.Character then
                    local tHrp = target.Character:FindFirstChild("HumanoidRootPart")
                    if tHrp then
                        local aimPos = tHrp.Position + tHrp.Velocity * Config.Aimbot.Prediction
                        local args = {...}
                        local modified = false
                        for i = 1, #args do
                            if typeof(args[i]) == "CFrame" then
                                args[i] = CFrame.new(aimPos)
                                modified = true
                            end
                        end
                        if modified then
                            return SilentAimState.OldNamecall(self, unpack(args))
                        end
                    end
                end
            end
        end
        return SilentAimState.OldNamecall(self, ...)
    end)

    SilentAimState.HookInstalled = true
    return true
end

local function SilentAimShoot()
    if not Config.SilentAim.Enabled then return end
    if tick() - SilentAimState.LastShotTime < SilentAimState.ShotCooldown then return end
    SilentAimState.LastShotTime = tick()

    local myChar = LocalPlayer.Character
    if not myChar then return end
    local tool = myChar:FindFirstChildWhichIsA("Tool")
    if not tool then return end
    if not (tool:FindFirstChild("GunScript") or tool.Name:lower():find("gun")) then return end

    pcall(function() tool:Activate() end)
end

task.spawn(function() task.wait(2); InstallSilentAimHook() end)

