-- ===== REACH LOGIC =====
local function HandleReach()
    local myChar = LocalPlayer.Character; 
    if not myChar then ReachCircle.Transparency = 1; return end
    local tool = myChar:FindFirstChildWhichIsA("Tool")
    local isHoldingKnife = tool and (tool:FindFirstChild("KnifeScript") or string.find(string.lower(tool.Name), "knife"))
    if isHoldingKnife and Config.Reach.Enabled then
        local handle = tool:FindFirstChild("Handle")
        if handle and handle:IsA("BasePart") then
            if Cache.OriginalHandleTool ~= tool then Cache.OriginalHandleSize = handle.Size; Cache.OriginalHandleTool = tool end
            local m = Config.Reach.Radius / 3; handle.Size = Cache.OriginalHandleSize * Vector3.new(m, m, m); handle.Transparency = 0.8; handle.CanCollide = false; handle.Massless = true
            local myHRP = myChar:FindFirstChild("HumanoidRootPart")
            if myHRP then ReachCircle.Transparency = 0.75; ReachCircle.Size = Vector3.new(0.15, Config.Reach.Radius * 2, Config.Reach.Radius * 2); ReachCircle.CFrame = myHRP.CFrame * CFrame.new(0, -2.5, 0) end
        end
    else
        if Cache.OriginalHandleTool and Cache.OriginalHandleSize then
            local oldHandle = Cache.OriginalHandleTool:FindFirstChild("Handle")
            if oldHandle and oldHandle:IsA("BasePart") then oldHandle.Size = Cache.OriginalHandleSize; oldHandle.Transparency = 0; oldHandle.CanCollide = true; oldHandle.Massless = false end
        end
        Cache.OriginalHandleSize = nil; Cache.OriginalHandleTool = nil; ReachCircle.Transparency = 1
    end
end

