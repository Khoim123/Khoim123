-- ===== XÁC ĐỊNH ROLE =====
local function GetRoleFromTool(name)
    local n = string.lower(name)
    if n:find("knife") or n:find("blade") or n:find("dagger") then return "Murderer" end
    if n:find("gun") or n:find("revolver") or n:find("pistol") then return "Sheriff" end
    if n:find("hero") then return "Hero" end
    return "Innocent"
end

local function UpdateRole(player)
    local char = player.Character
    if not char then return end
    local tool = char:FindFirstChildWhichIsA("Tool")
    if tool then Cache.Roles[player] = GetRoleFromTool(tool.Name); return end
    local backpack = player:FindFirstChild("Backpack")
    if backpack then
        for _, t in pairs(backpack:GetChildren()) do
            if t:IsA("Tool") then Cache.Roles[player] = GetRoleFromTool(t.Name); return end
        end
    end
    Cache.Roles[player] = "Innocent"
end

-- Vòng lặp ngầm cập nhật Role (Chống lag)
task.spawn(function()
    while task.wait(0.5) do
        for _, p in ipairs(Players:GetPlayers()) do
            UpdateRole(p)
        end
    end
end)

-- ===== AIMBOT THÔNG MINH =====
local function GetTarget()
    local myRole = Cache.Roles[LocalPlayer] or "Innocent"
    if myRole == "Innocent" then return nil end 
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local sheriffTarget, innocentTarget = nil, nil
    local sheriffDist, innocentDist = 200, 200

    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local targetRole = Cache.Roles[p] or "Innocent"
            local pos, onScreen = Camera:WorldToViewportPoint(p.Character.HumanoidRootPart.Position)
            if onScreen then
                local dist = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                if myRole == "Sheriff" and targetRole == "Murderer" and dist < sheriffDist then
                    sheriffTarget = p; sheriffDist = dist
                elseif myRole == "Murderer" then
                    if targetRole == "Sheriff" and dist < sheriffDist then
                        sheriffTarget = p; sheriffDist = dist
                    elseif targetRole == "Innocent" and dist < innocentDist then
                        innocentTarget = p; innocentDist = dist
                    end
                end
            end
        end
    end
    if myRole == "Sheriff" then return sheriffTarget end
    if myRole == "Murderer" then return sheriffTarget or innocentTarget end
    return nil
end

