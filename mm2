    -- ===== MOBILE BUTTON =====
    local function SetupMobileButton(gui, tapCallback)
        local currentInput = nil
        local holding = false
        local dragging = false
        local dragStartPos, guiStartPos = nil, nil

        local function isInBounds(pos)
            local gp = gui.AbsolutePosition; local gs = gui.AbsoluteSize
            return pos.X >= gp.X and pos.X <= gp.X + gs.X and pos.Y >= gp.Y and pos.Y <= gp.Y + gs.Y
        end

        gui.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
                if isInBounds(input.Position) then
                    currentInput = input; holding = true; dragging = false
                    dragStartPos = input.Position; guiStartPos = gui.Position
                end
            end
        end)

        gui.InputChanged:Connect(function(input)
            if input == currentInput and dragStartPos then
                local delta = input.Position - dragStartPos
                if not dragging and delta.Magnitude > 10 then dragging = true; holding = false end
                if dragging then
                    gui.Position = UDim2.new(guiStartPos.X.Scale, guiStartPos.X.Offset + delta.X, guiStartPos.Y.Scale, guiStartPos.Y.Offset + delta.Y)
                end
            end
        end)

        gui.InputEnded:Connect(function(input)
            if input == currentInput then
                if holding and tapCallback then task.spawn(tapCallback) end
                holding = false; dragging = false; currentInput = nil
            end
        end)
    end

