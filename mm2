-- Tạo nút bấm (Thiết kế dẹp, không chữ ON/OFF để tiết kiệm chỗ)
local function CreateBtn(text, initialState, pos, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 65, 0, 60)
    btn.Position = pos
    btn.BackgroundColor3 = initialState and Theme.Btn_On_BG or Theme.Btn_Off_BG
    btn.Text = text
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 14
    btn.TextColor3 = initialState and Theme.Btn_On_Text or Theme.Btn_Off_Text
    btn.AutoButtonColor = false
    btn.Parent = MainFrame
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
    local btnStroke = Instance.new("UIStroke", btn)
    btnStroke.Color = initialState and Theme.Btn_On_Stroke or Theme.Btn_Off_Stroke; btnStroke.Thickness = 1.2

    btn.MouseButton1Click:Connect(function()
        local newState = callback()
        btn.BackgroundColor3 = newState and Theme.Btn_On_BG or Theme.Btn_Off_BG
        btn.TextColor3 = newState and Theme.Btn_On_Text or Theme.Btn_Off_Text
        btnStroke.Color = newState and Theme.Btn_On_Stroke or Theme.Btn_Off_Stroke
    end)
end

