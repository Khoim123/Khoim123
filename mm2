-- ===== GUN DROP ESP =====
local function IsGunDrop(obj)
    return obj:IsA("Tool") and (obj.Name:lower():find("gun") or obj.Name:lower():find("revolver"))
end

local function TrackGunDrop(obj)
    if not IsGunDrop(obj) or Cache.GunDrops[obj] then return end
    
    local handle = obj:FindFirstChild("Handle") or obj:FindFirstChildWhichIsA("BasePart")
    if not handle then return end
    
    local hl = Instance.new("Highlight")
    hl.FillColor = Config.GunDrop.Color
    hl.OutlineColor = Color3.fromRGB(255, 255, 255)
    hl.FillTransparency = 0.3
    hl.OutlineTransparency = 0.2
    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    hl.Parent = obj
    
    local bill = Instance.new("BillboardGui")
    bill.Adornee = handle
    bill.Size = UDim2.new(0, 100, 0, 30)
    bill.StudsOffset = Vector3.new(0, 2, 0)
    bill.AlwaysOnTop = true
    bill.Parent = handle
    
    local txt = Instance.new("TextLabel")
    txt.Size = UDim2.new(1, 0, 1, 0)
    txt.BackgroundTransparency = 1
    txt.TextScaled = true
    txt.Font = Enum.Font.GothamBold
    txt.TextStrokeTransparency = 0.3
    txt.Parent = bill
    
    Cache.GunDrops[obj] = {HL = hl, Bill = bill, Txt = txt, Handle = handle, Object = obj}
end

workspace.ChildAdded:Connect(TrackGunDrop)for _, obj in ipairs(workspace:GetChildren()) do TrackGunDrop(obj) end

-- ===== MAIN UPDATE LOOP =====
RunService.Heartbeat:Connect(function(dt)
    local camPos = Camera.CFrame.Position
    
    -- Update Player ESP
    for _, espData in pairs(Cache.ESPs) do
        local player = espData.Player
        local char = espData.Char
        if not player.Parent or not char.Parent then
            espData.HL:Destroy()
            espData.Bill:Destroy()
            espData.Tracer:Destroy()
            for _, att in ipairs(espData.Attachments) do att:Destroy() end
            Cache.ESPs[player] = nil
            continue
        end
        
        local dist = (camPos - espData.HRP.Position).Magnitude
        local isVisible = dist < Config.ESP.MaxDistance
        
        if Config.ESP.Enabled and isVisible then
            local role = GetPlayerRole(player)
            local color = role == "Murderer" and Color3.fromRGB(255, 40, 40) or 
                          role == "Sheriff" and Color3.fromRGB(40, 120, 255) or
                          role == "Hero" and Color3.fromRGB(255, 200, 0) or Color3.fromRGB(120, 120, 120)
            
            local fade = dist > Config.ESP.FadeStart and math.max(0, 1 - (dist - Config.ESP.FadeStart) / (Config.ESP.MaxDistance - Config.ESP.FadeStart)) or 1
            local alpha = math.max(0.1, fade)
            
            espData.HL.Enabled = true
            espData.HL.FillColor = color
            espData.HL.OutlineColor = color
            espData.HL.FillTransparency = 1 - (alpha * 0.4)
            
            espData.Tracer.Enabled = Config.ESP.ShowTracer
            if Config.ESP.ShowTracer then
                espData.Tracer.Transparency = NumberSequence.new(1 - alpha)
                espData.Tracer.Color = ColorSequence.new(color)
            end
            
            espData.Bill.Enabled = true
            local info = Config.ESP.ShowNames and player.DisplayName or ""
            info = info .. (Config.ESP.ShowRole and "\n[" .. role .. "]" or "")
            info = info .. (Config.ESP.ShowDistance and "\n" .. math.floor(dist) .. "m" or "")
            espData.Txt.Text = info
            espData.Txt.TextColor3 = color
        else
            espData.HL.Enabled = false            espData.Bill.Enabled = false
            espData.Tracer.Enabled = false
        end
    end
    
    -- Update Gun Drop ESP
    for obj, dropData in pairs(Cache.GunDrops) do
        if not obj.Parent then
            dropData.HL:Destroy()
            dropData.Bill:Destroy()
            Cache.GunDrops[obj] = nil
            continue
        end
        
        if Config.GunDrop.Enabled then
            local dist = (camPos - dropData.Handle.Position).Magnitude
            dropData.HL.Enabled = true
            dropData.Bill.Enabled = true
            dropData.Txt.Text = "🔫 SÚNG RỚT" .. (Config.GunDrop.ShowDistance and ("\n" .. math.floor(dist) .. "m") or "")
            dropData.Txt.TextColor3 = Config.GunDrop.Color
        else
            dropData.HL.Enabled = false
            dropData.Bill.Enabled = false
        end
    end
end)

